# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
COOKIE_NAME=studyhere_token

# Database (Postgres)
DATABASE_URL="postgresql://studyhere:studyhere@localhost:5432/studyhere?schema=public"

# mediasoup
# Set to the public IP of the machine running this server (use your LAN IP for
# local testing across devices, or your server's public IP in production).
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100
